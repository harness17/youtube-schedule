{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const d=[];process.stdin.on('data',c=>d.push(c));process.stdin.on('end',()=>{const j=JSON.parse(Buffer.concat(d).toString());const f=(j.tool_input&&j.tool_input.file_path)||(j.tool_response&&j.tool_response.filePath)||'';if(f&&/\\.(js|jsx|ts|tsx|css|json|mjs|cjs)$/.test(f)){const {execSync}=require('child_process');try{execSync('npx prettier --write \\\"'+f+'\\\"',{stdio:'inherit',cwd:'H:/ClaudeCode/Youtube/youtube-schedule'});}catch(e){}}})\" 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Prettier でフォーマット中..."
          }
        ]
      }
    ]
  }
}
